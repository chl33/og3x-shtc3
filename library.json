{
    "name": "og3x-shtc3",
    "version": "0.5.0",
    "description": "Add support for SHTC3 sensor to chl33/og3",
    "keywords": "esp32, esp8266, shtc3",
    "authors": [
        {
            "name": "Chris Lee",
            "email": "lee.chris.h@gmail.com",
            "url": "https://selectiveappeal.org/",
            "maintainer": true
        }
    ],
    "dependencies": {
        "og3": "~0.6.0",
        "adafruit/Adafruit SHTC3 Library": "~1.0.0",
        "adafruit/Adafruit BusIO": "~1.17.4",
        "adafruit/Adafruit Unified Sensor": "~1.1.0",
        "Wire": "*",
        "SPI": "*"
    },
    "export": {
        "exclude": [
            ".*",
            "*~",
            "util/"
        ]
    },
    "license": "MIT",
    "frameworks": "*",
    "platforms": "espressif8266, espressif32, native",
    "repository": {
        "type": "git",
        "url": "https://github.com/chl33/og3x-shtc3"
    },
    "build": {
        "libLDFMode": "deep+",
        "libCompatMode": "strict"
    }
}
